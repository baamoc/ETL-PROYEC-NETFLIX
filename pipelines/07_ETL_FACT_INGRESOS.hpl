  <transform>
    <name>Filtrar_Registros_Validos</name>
    <type>FilterRows</type>
    <description>Descarta registros donde id_usuario o fecha_pago son nulos; sin ellos no hay FK valida para el hecho</description>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <compare>
      <condition>
        <conditions>
          <condition>
            <conditions>
</conditions>
            <function>IS NOT NULL</function>
            <leftvalue>id_usuario</leftvalue>
            <negated>N</negated>
            <operator>-</operator>
          </condition>
          <condition>
            <conditions>
</conditions>
            <function>IS NOT NULL</function>
            <leftvalue>fecha_pago</leftvalue>
            <negated>N</negated>
            <operator>AND</operator>
          </condition>
          <condition>
            <conditions>
</conditions>
            <function>IS NOT NULL</function>
            <leftvalue>ingreso_mensual</leftvalue>
            <negated>N</negated>
            <operator>AND</operator>
          </condition>
        </conditions>
        <function>=</function>
        <negated>N</negated>
        <operator>-</operator>
      </condition>
    </compare>
    <send_true_to>SL_Buscar_id_suscripcion</send_true_to>
    <attributes/>
    <GUI>
      <xloc>1344</xloc>
      <yloc>400</yloc>
    </GUI>
  </transform>
  <transform>
    <name>JS_Preparar_Ingresos</name>
    <type>ScriptValueMod</type>
    <description>Convierte user_id a Integer, normaliza strings a proper case y parsea last_payment_date a Date e ingreso_mensual a Number</description>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <optimizationLevel>9</optimizationLevel>
    <jsScripts>
      <jsScript>
        <jsScript_type>0</jsScript_type>
        <jsScript_name>Script 1</jsScript_name>
        <jsScript_script>
// Convert user_id String to Integer
var id_usuario = null;
if (user_id != null &amp;&amp; user_id.trim() != '') {
  var parsedId = parseInt(user_id.trim(), 10);
  if (!isNaN(parsedId) &amp;&amp; parsedId > 0) {
    id_usuario = parsedId;
  }
}

// Normalize subscription_type to proper case (Basic, Standard, Premium)
var tipo_suscripcion_norm = 'Sin dato';
if (subscription_type != null &amp;&amp; subscription_type.trim() != '' &amp;&amp; subscription_type.trim() != 'Sin dato') {
  var st = subscription_type.trim();
  tipo_suscripcion_norm = st.charAt(0).toUpperCase() + st.substring(1).toLowerCase();
}

// Normalize device to proper case word by word (Smart Tv, Laptop, Tablet, Smartphone)
var nombre_dispositivo_norm = 'Sin dato';
if (device != null &amp;&amp; device.trim() != '' &amp;&amp; device.trim() != 'Sin dato') {
  var dWords = device.trim().split(' ');
  var dResult = [];
  for (var i = 0; i &lt; dWords.length; i++) {
    if (dWords[i].length > 0) {
      dResult.push(dWords[i].charAt(0).toUpperCase() + dWords[i].substring(1).toLowerCase());
    }
  }
  nombre_dispositivo_norm = dResult.join(' ');
}

// Normalize country to proper case word by word (United States, United Kingdom, etc.)
var nombre_pais_norm = 'Sin dato';
if (country != null &amp;&amp; country.trim() != '' &amp;&amp; country.trim() != 'Sin dato') {
  var cWords = country.trim().split(' ');
  var cResult = [];
  for (var i = 0; i &lt; cWords.length; i++) {
    if (cWords[i].length > 0) {
      cResult.push(cWords[i].charAt(0).toUpperCase() + cWords[i].substring(1).toLowerCase());
    }
  }
  nombre_pais_norm = cResult.join(' ');
}

// Parse last_payment_date DD-MM-YY to Date
var fecha_pago = null;
if (last_payment_date != null &amp;&amp; last_payment_date.trim() != '' &amp;&amp; last_payment_date.trim() != 'Sin dato') {
  var parts = last_payment_date.trim().split('-');
  if (parts.length == 3) {
    var d = parseInt(parts[0], 10);
    var m = parseInt(parts[1], 10);
    var y_raw = parseInt(parts[2], 10);
    var y = y_raw &lt; 100 ? 2000 + y_raw : y_raw;
    if (!isNaN(d) &amp;&amp; !isNaN(m) &amp;&amp; !isNaN(y) &amp;&amp; d >= 1 &amp;&amp; d &lt;= 31 &amp;&amp; m >= 1 &amp;&amp; m &lt;= 12) {
      var cal = java.util.Calendar.getInstance();
      cal.set(y, m - 1, d, 0, 0, 0);
      cal.set(java.util.Calendar.MILLISECOND, 0);
      fecha_pago = cal.getTime();
    }
  }
}

// Parse monthly_revenue to Number
var ingreso_mensual = null;
if (monthly_revenue != null &amp;&amp; monthly_revenue.trim() != '') {
  var parsedRev = parseFloat(monthly_revenue.trim());
  if (!isNaN(parsedRev) &amp;&amp; parsedRev >= 0) {
    ingreso_mensual = parsedRev;
  }
}
        </jsScript_script>
      </jsScript>
    </jsScripts>
