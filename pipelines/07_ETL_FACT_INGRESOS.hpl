  <transform>
    <name>LEER_INGRESOS_DESDE_STAGING_CON_DIMENSIONES</name>
    <type>TableInput</type>
    <description/>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <connection>Proyecto-Neonbd</connection>
    <execute_each_row>N</execute_each_row>
    <limit>0</limit>
    <sql>SELECT
    u.id_usuario,
    s.id_suscripcion,
    d.id_dispositivo,
    p.id_pais,
    t.id_tiempo,
    ub."Monthly Revenue"::numeric AS ingreso_mensual
FROM staging.stg_netflix_userbase ub
LEFT JOIN dm_streaming.dim_usuario u
    ON u.id_usuario = ub."User ID"::integer
LEFT JOIN dm_streaming.dim_suscripcion s
    ON s.tipo_suscripcion = TRIM(ub."Subscription Type")
   AND s.duracion_plan = TRIM(ub."Plan Duration")
LEFT JOIN dm_streaming.dim_dispositivo d
    ON d.nombre_dispositivo = TRIM(ub.device)
LEFT JOIN dm_streaming.dim_pais p
    ON p.nombre_pais = TRIM(ub.country)
LEFT JOIN dm_streaming.dim_tiempo t
    ON t.fecha_completa = ub."Last Payment Date"::date;</sql>
    <variables_active>N</variables_active>
    <attributes/>
    <GUI>
      <xloc>224</xloc>
      <yloc>80</yloc>
    </GUI>
