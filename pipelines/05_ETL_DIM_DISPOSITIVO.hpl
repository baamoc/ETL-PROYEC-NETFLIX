<?xml version="1.0" encoding="UTF-8"?>
<pipeline>
  <info>
    <name>05_ETL_DIM_DISPOSITIVO</name>
    <name_sync_with_filename>Y</name_sync_with_filename>
    <description>ETL dimension dim_dispositivo desde stg_netflix_userbase</description>
    <extended_description/>
    <pipeline_version/>
    <pipeline_type>Normal</pipeline_type>
    <parameters>
    </parameters>
    <capture_transform_performance>N</capture_transform_performance>
    <transform_performance_capturing_delay>1000</transform_performance_capturing_delay>
    <transform_performance_capturing_size_limit>100</transform_performance_capturing_size_limit>
    <created_user>-</created_user>
    <created_date>2026/06/09 00:00:00.000</created_date>
    <modified_user>-</modified_user>
    <modified_date>2026/06/09 00:00:00.000</modified_date>
  </info>
  <notepads>
  </notepads>
  <order>
    <hop>
      <from>Leer_STG_Dispositivos</from>
      <to>Sel_Campos_Dispositivo</to>
      <enabled>Y</enabled>
    </hop>
    <hop>
      <from>Sel_Campos_Dispositivo</from>
      <to>Limpiar_Textos_Dispositivo</to>
      <enabled>Y</enabled>
    </hop>
    <hop>
      <from>Limpiar_Textos_Dispositivo</from>
      <to>Corregir_Textos_Dispositivo</to>
      <enabled>Y</enabled>
    </hop>
    <hop>
      <from>Corregir_Textos_Dispositivo</from>
      <to>JS_Normalizar_Dispositivo</to>
      <enabled>Y</enabled>
    </hop>
    <hop>
      <from>JS_Normalizar_Dispositivo</from>
      <to>Sel_Campos_Final</to>
      <enabled>Y</enabled>
    </hop>
    <hop>
      <from>Sel_Campos_Final</from>
      <to>Ordenar_Dispositivos</to>
      <enabled>Y</enabled>
    </hop>
    <hop>
      <from>Ordenar_Dispositivos</from>
      <to>Eliminar_Duplicados</to>
      <enabled>Y</enabled>
    </hop>
    <hop>
      <from>Eliminar_Duplicados</from>
      <to>Validar_Dispositivo</to>
      <enabled>Y</enabled>
    </hop>
    <hop>
      <from>Validar_Dispositivo</from>
      <to>Cargar_DIM_Dispositivo</to>
      <enabled>Y</enabled>
    </hop>
  </order>
  <transform>
    <name>Cargar_DIM_Dispositivo</name>
    <type>InsertUpdate</type>
    <description>Upsert en dm_streaming.dim_dispositivo; lookup por nombre_dispositivo evita duplicados en re-ejecuciones</description>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <commit>100</commit>
    <connection>Proyecto-Neonbd</connection>
    <lookup>
      <key>
        <condition>=</condition>
        <field>nombre_dispositivo</field>
        <name>nombre_dispositivo</name>
        <name2/>
      </key>
      <schema>dm_streaming</schema>
      <table>dim_dispositivo</table>
      <value>
        <name>nombre_dispositivo</name>
        <rename>nombre_dispositivo</rename>
        <update>N</update>
      </value>
    </lookup>
    <update_bypassed>N</update_bypassed>
    <attributes/>
    <GUI>
      <xloc>608</xloc>
      <yloc>464</yloc>
    </GUI>
  </transform>
  <transform>
    <name>Corregir_Textos_Dispositivo</name>
    <type>ReplaceString</type>
    <description>Reemplaza strings vacios en device por Sin dato</description>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <fields>
      <field>
        <case_sensitive>Y</case_sensitive>
        <in_stream_name>device</in_stream_name>
        <is_unicode>N</is_unicode>
        <replace_by_string>Sin dato</replace_by_string>
        <replace_string>^\s*$</replace_string>
        <set_empty_string>N</set_empty_string>
        <use_regex>Y</use_regex>
        <whole_word>N</whole_word>
      </field>
    </fields>
    <attributes/>
    <GUI>
      <xloc>672</xloc>
      <yloc>208</yloc>
    </GUI>
  </transform>
  <transform>
    <name>Eliminar_Duplicados</name>
    <type>Unique</type>
    <description>Elimina dispositivos duplicados por nombre_dispositivo; requiere stream ordenado</description>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <count_rows>N</count_rows>
    <fields>
      <field>
        <case_insensitive>N</case_insensitive>
        <name>nombre_dispositivo</name>
      </field>
    </fields>
    <reject_duplicate_row>N</reject_duplicate_row>
    <attributes/>
    <GUI>
      <xloc>224</xloc>
      <yloc>432</yloc>
    </GUI>
  </transform>
  <transform>
    <name>JS_Normalizar_Dispositivo</name>
    <type>ScriptValueMod</type>
    <description>Normaliza nombre de dispositivo a formato titulo palabra por palabra (Smart Tv, Laptop, Tablet)</description>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <optimizationLevel>9</optimizationLevel>
    <jsScripts>
      <jsScript>
        <jsScript_type>0</jsScript_type>
        <jsScript_name>Script 1</jsScript_name>
        <jsScript_script>
// Proper case word by word to normalize device names (Smart TV, Laptop, Tablet, Smartphone)
var nombre_dispositivo = 'Sin dato';
if (device != null &amp;&amp; device.trim() != '' &amp;&amp; device.trim() != 'Sin dato') {
  var words = device.trim().split(' ');
  var result = [];
  for (var i = 0; i &lt; words.length; i++) {
    if (words[i].length > 0) {
      result.push(words[i].charAt(0).toUpperCase() + words[i].substring(1).toLowerCase());
    }
  }
  nombre_dispositivo = result.join(' ');
}
        </jsScript_script>
      </jsScript>
    </jsScripts>
    <fields>
      <field>
        <name>nombre_dispositivo</name>
        <rename>nombre_dispositivo</rename>
        <type>String</type>
        <length>-1</length>
        <precision>-1</precision>
        <replace>N</replace>
      </field>
    </fields>
    <attributes/>
    <GUI>
      <xloc>864</xloc>
      <yloc>208</yloc>
    </GUI>
  </transform>
  <transform>
    <name>Leer_STG_Dispositivos</name>
    <type>TableInput</type>
    <description>Extrae device desde staging sin transformaciones en SQL</description>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <connection>Proyecto-Neonbd</connection>
    <execute_each_row>N</execute_each_row>
    <limit>0</limit>
    <sql>SELECT device
FROM staging.stg_netflix_userbase
WHERE device IS NOT NULL</sql>
    <variables_active>N</variables_active>
    <attributes/>
    <GUI>
      <xloc>288</xloc>
      <yloc>48</yloc>
    </GUI>
  </transform>
  <transform>
    <name>Limpiar_Textos_Dispositivo</name>
    <type>StringOperations</type>
    <description>Aplica trim al campo device para eliminar espacios sobrantes</description>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <fields>
      <field>
        <in_stream_name>device</in_stream_name>
        <out_stream_name/>
        <trim_type>both</trim_type>
        <lower_upper>none</lower_upper>
        <padding_type>none</padding_type>
        <pad_char/>
        <pad_len/>
        <init_cap>no</init_cap>
        <mask_xml>none</mask_xml>
        <digits>none</digits>
        <remove_special_characters>none</remove_special_characters>
      </field>
    </fields>
    <attributes/>
    <GUI>
      <xloc>480</xloc>
      <yloc>208</yloc>
    </GUI>
  </transform>
  <transform>
    <name>Ordenar_Dispositivos</name>
    <type>SortRows</type>
    <description>Ordena por nombre_dispositivo para habilitar la deduplicacion siguiente</description>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <compress>N</compress>
    <fields>
      <field>
        <ascending>Y</ascending>
        <case_sensitive>N</case_sensitive>
        <collator_enabled>N</collator_enabled>
        <collator_strength>0</collator_strength>
        <name>nombre_dispositivo</name>
        <presorted>N</presorted>
      </field>
    </fields>
    <sort_size>1000000</sort_size>
    <unique_rows>N</unique_rows>
    <attributes/>
    <GUI>
      <xloc>960</xloc>
      <yloc>336</yloc>
    </GUI>
  </transform>
  <transform>
    <name>Sel_Campos_Dispositivo</name>
    <type>SelectValues</type>
    <description>Selecciona el campo device para la dimension dispositivo</description>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <fields>
      <field>
        <length>-2</length>
        <name>device</name>
        <precision>-2</precision>
        <rename>device</rename>
      </field>
      <select_unspecified>N</select_unspecified>
    </fields>
    <attributes/>
    <GUI>
      <xloc>480</xloc>
      <yloc>48</yloc>
    </GUI>
  </transform>
  <transform>
    <name>Sel_Campos_Final</name>
    <type>SelectValues</type>
    <description>Conserva solo nombre_dispositivo generado por el JS con nombre del modelo DM</description>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <fields>
      <field>
        <length>-2</length>
        <name>nombre_dispositivo</name>
        <precision>-2</precision>
        <rename>nombre_dispositivo</rename>
      </field>
      <select_unspecified>N</select_unspecified>
    </fields>
    <attributes/>
    <GUI>
      <xloc>704</xloc>
      <yloc>320</yloc>
    </GUI>
  </transform>
  <transform>
    <name>Validar_Dispositivo</name>
    <type>FilterRows</type>
    <description>Descarta registros donde nombre_dispositivo quedo nulo tras la normalizacion JS</description>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <compare>
      <condition>
        <conditions>
</conditions>
        <function>IS NOT NULL</function>
        <leftvalue>nombre_dispositivo</leftvalue>
        <negated>N</negated>
        <operator>-</operator>
      </condition>
    </compare>
    <send_true_to>Cargar_DIM_Dispositivo</send_true_to>
    <attributes/>
    <GUI>
      <xloc>416</xloc>
      <yloc>432</yloc>
    </GUI>
  </transform>
  <transform_error_handling>
  </transform_error_handling>
  <attributes/>
</pipeline>
