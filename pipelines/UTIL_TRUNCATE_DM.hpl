<?xml version="1.0" encoding="UTF-8"?>
<pipeline>
  <info>
    <name>UTIL_TRUNCATE_DM</name>
    <name_sync_with_filename>Y</name_sync_with_filename>
    <description>Utilidad: trunca todas las tablas del DM en orden correcto (facts primero, luego dims)</description>
    <extended_description/>
    <pipeline_version/>
    <pipeline_type>Normal</pipeline_type>
    <parameters>
    </parameters>
    <capture_transform_performance>N</capture_transform_performance>
    <transform_performance_capturing_delay>1000</transform_performance_capturing_delay>
    <transform_performance_capturing_size_limit>100</transform_performance_capturing_size_limit>
    <created_user>-</created_user>
    <created_date>2026/06/10 00:00:00.000</created_date>
    <modified_user>-</modified_user>
    <modified_date>2026/06/10 00:00:00.000</modified_date>
  </info>
  <notepads>
  </notepads>
  <order>
    <hop>
      <from>Generar_Fila</from>
      <to>Truncar_Tablas_DM</to>
      <enabled>Y</enabled>
    </hop>
  </order>
  <transform>
    <name>Generar_Fila</name>
    <type>RowGenerator</type>
    <description>Genera una fila vacia para disparar el Execute SQL Script</description>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <fields/>
    <limit>1</limit>
    <never_ending>N</never_ending>
    <interval_in_ms>5000</interval_in_ms>
    <row_time_field>now</row_time_field>
    <last_time_field>FiveSecondsAgo</last_time_field>
    <attributes/>
    <GUI>
      <xloc>176</xloc>
      <yloc>208</yloc>
    </GUI>
  </transform>
  <transform>
    <name>Truncar_Tablas_DM</name>
    <type>ExecSQL</type>
    <description>Trunca facts primero (por FK), luego todas las dims con CASCADE</description>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <connection>Proyecto-Neonbd</connection>
    <execute_each_row>N</execute_each_row>
    <single_statement>N</single_statement>
    <replace_variables>N</replace_variables>
    <quoteString>N</quoteString>
    <sql>TRUNCATE dm_streaming.fact_consumo, dm_streaming.fact_ingresos, dm_streaming.dim_usuario, dm_streaming.dim_pais, dm_streaming.dim_dispositivo, dm_streaming.dim_tiempo, dm_streaming.dim_contenido, dm_streaming.dim_suscripcion CASCADE</sql>
    <attributes/>
    <GUI>
      <xloc>432</xloc>
      <yloc>208</yloc>
    </GUI>
  </transform>
  <transform_error_handling>
  </transform_error_handling>
  <attributes/>
</pipeline>
