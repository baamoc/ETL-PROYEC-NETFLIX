  <transform>
    <name>JS_Normalizar_Contenido</name>
    <type>ScriptValueMod</type>
    <description>Normaliza tipo_contenido a formato titulo; convierte release_year de String a Integer con validacion de rango</description>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <optimizationLevel>9</optimizationLevel>
    <jsScripts>
      <jsScript>
        <jsScript_type>0</jsScript_type>
        <jsScript_name>Script 1</jsScript_name>
        <jsScript_script>
// Normalize tipo_contenido — preserve "TV Show" uppercase correctly
var tipo_contenido = 'Sin dato';
if (type != null &amp;&amp; type.trim() != '' &amp;&amp; type.trim() != 'Sin dato') {
  var t = type.trim().toUpperCase();
  if (t == 'TV SHOW' || t == 'TVSHOW') {
    tipo_contenido = 'TV Show';
  } else if (t == 'MOVIE') {
    tipo_contenido = 'Movie';
  } else {
    var w = type.trim();
    tipo_contenido = w.charAt(0).toUpperCase() + w.substring(1).toLowerCase();
  }
}

// Convert release_year String to Integer with range validation
var anio_lanzamiento = null;
if (release_year != null &amp;&amp; release_year.trim() != '' &amp;&amp; release_year.trim() != 'Sin dato') {
  var parsed = parseInt(release_year.trim(), 10);
  if (!isNaN(parsed) &amp;&amp; parsed > 1900 &amp;&amp; parsed &lt;= 2030) {
    anio_lanzamiento = parsed;
  }
}
        </jsScript_script>
      </jsScript>
    </jsScripts>
    <fields>
      <field>
        <name>tipo_contenido</name>
        <rename>tipo_contenido</rename>
        <type>String</type>
        <length>-1</length>
        <precision>-1</precision>
        <replace>N</replace>
      </field>
      <field>
        <name>anio_lanzamiento</name>
        <rename>anio_lanzamiento</rename>
        <type>Integer</type>
        <length>-1</length>
        <precision>-1</precision>
        <replace>N</replace>
      </field>
    </fields>
    <attributes/>
    <GUI>
      <xloc>864</xloc>
      <yloc>208</yloc>
    </GUI>
