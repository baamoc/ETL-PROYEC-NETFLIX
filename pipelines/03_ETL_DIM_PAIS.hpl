<?xml version="1.0" encoding="UTF-8"?>
<pipeline>
  <info>
    <name>03_ETL_DIM_PAIS</name>
    <name_sync_with_filename>Y</name_sync_with_filename>
    <description>ETL dimension dim_pais desde stg_netflix_userbase</description>
    <extended_description/>
    <pipeline_version/>
    <pipeline_type>Normal</pipeline_type>
    <parameters>
    </parameters>
    <capture_transform_performance>N</capture_transform_performance>
    <transform_performance_capturing_delay>1000</transform_performance_capturing_delay>
    <transform_performance_capturing_size_limit>100</transform_performance_capturing_size_limit>
    <created_user>-</created_user>
    <created_date>2026/06/09 00:00:00.000</created_date>
    <modified_user>-</modified_user>
    <modified_date>2026/06/09 00:00:00.000</modified_date>
  </info>
  <notepads>
  </notepads>
  <order>
    <hop>
      <from>Leer_STG_Paises</from>
      <to>Sel_Campos_Pais</to>
      <enabled>Y</enabled>
    </hop>
    <hop>
      <from>Sel_Campos_Pais</from>
      <to>Limpiar_Textos_Pais</to>
      <enabled>Y</enabled>
    </hop>
    <hop>
      <from>Limpiar_Textos_Pais</from>
      <to>Corregir_Textos_Pais</to>
      <enabled>Y</enabled>
    </hop>
    <hop>
      <from>Corregir_Textos_Pais</from>
      <to>JS_Normalizar_Pais</to>
      <enabled>Y</enabled>
    </hop>
    <hop>
      <from>JS_Normalizar_Pais</from>
      <to>Sel_Campos_Final</to>
      <enabled>Y</enabled>
    </hop>
    <hop>
      <from>Sel_Campos_Final</from>
      <to>Ordenar_Paises</to>
      <enabled>Y</enabled>
    </hop>
    <hop>
      <from>Ordenar_Paises</from>
      <to>Eliminar_Duplicados</to>
      <enabled>Y</enabled>
    </hop>
    <hop>
      <from>Eliminar_Duplicados</from>
      <to>Validar_Pais</to>
      <enabled>Y</enabled>
    </hop>
    <hop>
      <from>Validar_Pais</from>
      <to>Cargar_DIM_Pais</to>
      <enabled>Y</enabled>
    </hop>
  </order>
  <transform>
    <name>Cargar_DIM_Pais</name>
    <type>TableOutput</type>
    <description>Carga masiva con truncate en dm_streaming.dim_pais; bulk insert mas rapido que InsertUpdate en Neon</description>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <add_columns>N</add_columns>
    <always_drop_and_recreate>N</always_drop_and_recreate>
    <auto_update_table_structure>N</auto_update_table_structure>
    <change_column_types>N</change_column_types>
    <commit>1000</commit>
    <connection>Proyecto-Neonbd</connection>
    <drop_columns>N</drop_columns>
    <fields>
</fields>
    <ignore_errors>N</ignore_errors>
    <only_when_have_rows>N</only_when_have_rows>
    <partitioning_daily>N</partitioning_daily>
    <partitioning_enabled>N</partitioning_enabled>
    <partitioning_monthly>N</partitioning_monthly>
    <return_keys>N</return_keys>
    <schema>dm_streaming</schema>
    <specify_fields>N</specify_fields>
    <table>dim_pais</table>
    <tablename_in_field>N</tablename_in_field>
    <tablename_in_table>N</tablename_in_table>
    <truncate>N</truncate>
    <use_batch>Y</use_batch>
    <attributes/>
    <GUI>
      <xloc>1440</xloc>
      <yloc>464</yloc>
    </GUI>
  </transform>
  <transform>
    <name>Corregir_Textos_Pais</name>
    <type>ReplaceString</type>
    <description>Reemplaza strings vacios en country por Sin dato</description>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <fields>
      <field>
        <case_sensitive>Y</case_sensitive>
        <in_stream_name>country</in_stream_name>
        <is_unicode>N</is_unicode>
        <replace_by_string>Sin dato</replace_by_string>
        <replace_string>^\s*$</replace_string>
        <set_empty_string>N</set_empty_string>
        <use_regex>Y</use_regex>
        <whole_word>N</whole_word>
      </field>
    </fields>
    <attributes/>
    <GUI>
      <xloc>480</xloc>
      <yloc>304</yloc>
    </GUI>
  </transform>
  <transform>
    <name>Eliminar_Duplicados</name>
    <type>Unique</type>
    <description>Elimina paises duplicados por nombre_pais; requiere stream ordenado</description>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <count_rows>N</count_rows>
    <fields>
      <field>
        <case_insensitive>N</case_insensitive>
        <name>nombre_pais</name>
      </field>
    </fields>
    <reject_duplicate_row>N</reject_duplicate_row>
    <attributes/>
    <GUI>
      <xloc>1056</xloc>
      <yloc>464</yloc>
    </GUI>
  </transform>
  <transform>
    <name>JS_Normalizar_Pais</name>
    <type>ScriptValueMod</type>
    <description>Normaliza nombre de pais a formato titulo (proper case) palabra por palabra</description>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <optimizationLevel>9</optimizationLevel>
    <jsScripts>
      <jsScript>
        <jsScript_type>0</jsScript_type>
        <jsScript_name>Script 1</jsScript_name>
        <jsScript_script>
// Proper case word by word to handle "United States", "United Kingdom", etc.
var nombre_pais = 'Sin dato';
if (country != null &amp;&amp; country.trim() != '' &amp;&amp; country.trim() != 'Sin dato') {
  var words = country.trim().split(' ');
  var result = [];
  for (var i = 0; i &lt; words.length; i++) {
    if (words[i].length > 0) {
      result.push(words[i].charAt(0).toUpperCase() + words[i].substring(1).toLowerCase());
    }
  }
  nombre_pais = result.join(' ');
}
        </jsScript_script>
      </jsScript>
    </jsScripts>
    <fields>
      <field>
        <name>nombre_pais</name>
        <rename>nombre_pais</rename>
        <type>String</type>
        <length>-1</length>
        <precision>-1</precision>
        <replace>N</replace>
      </field>
    </fields>
    <attributes/>
    <GUI>
      <xloc>672</xloc>
      <yloc>304</yloc>
    </GUI>
  </transform>
  <transform>
    <name>Leer_STG_Paises</name>
    <type>TableInput</type>
    <description>Extrae country desde staging sin transformaciones en SQL</description>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <connection>Proyecto-Neonbd</connection>
    <execute_each_row>N</execute_each_row>
    <limit>0</limit>
    <sql>SELECT country
FROM staging.stg_netflix_userbase
WHERE country IS NOT NULL</sql>
    <variables_active>N</variables_active>
    <attributes/>
    <GUI>
      <xloc>96</xloc>
      <yloc>208</yloc>
    </GUI>
  </transform>
  <transform>
    <name>Limpiar_Textos_Pais</name>
    <type>StringOperations</type>
    <description>Aplica trim al campo country para eliminar espacios sobrantes</description>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <fields>
      <field>
        <in_stream_name>country</in_stream_name>
        <out_stream_name/>
        <trim_type>both</trim_type>
        <lower_upper>none</lower_upper>
        <padding_type>none</padding_type>
        <pad_char/>
        <pad_len/>
        <init_cap>no</init_cap>
        <mask_xml>none</mask_xml>
        <digits>none</digits>
        <remove_special_characters>none</remove_special_characters>
      </field>
    </fields>
    <attributes/>
    <GUI>
      <xloc>480</xloc>
      <yloc>208</yloc>
    </GUI>
  </transform>
  <transform>
    <name>Ordenar_Paises</name>
    <type>SortRows</type>
    <description>Ordena por nombre_pais para habilitar la deduplicacion siguiente</description>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <compress>N</compress>
    <fields>
      <field>
        <ascending>Y</ascending>
        <case_sensitive>N</case_sensitive>
        <collator_enabled>N</collator_enabled>
        <collator_strength>0</collator_strength>
        <name>nombre_pais</name>
        <presorted>N</presorted>
      </field>
    </fields>
    <sort_size>1000000</sort_size>
    <unique_rows>N</unique_rows>
    <attributes/>
    <GUI>
      <xloc>1056</xloc>
      <yloc>304</yloc>
    </GUI>
  </transform>
  <transform>
    <name>Sel_Campos_Final</name>
    <type>SelectValues</type>
    <description>Conserva solo nombre_pais generado por el JS con nombre del modelo DM</description>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <fields>
      <field>
        <length>-2</length>
        <name>nombre_pais</name>
        <precision>-2</precision>
        <rename>nombre_pais</rename>
      </field>
      <select_unspecified>N</select_unspecified>
    </fields>
    <attributes/>
    <GUI>
      <xloc>864</xloc>
      <yloc>304</yloc>
    </GUI>
  </transform>
  <transform>
    <name>Sel_Campos_Pais</name>
    <type>SelectValues</type>
    <description>Selecciona el campo country para la dimension pais</description>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <fields>
      <field>
        <length>-2</length>
        <name>country</name>
        <precision>-2</precision>
        <rename>country</rename>
      </field>
      <select_unspecified>N</select_unspecified>
    </fields>
    <attributes/>
    <GUI>
      <xloc>288</xloc>
      <yloc>208</yloc>
    </GUI>
  </transform>
  <transform>
    <name>Validar_Pais</name>
    <type>FilterRows</type>
    <description>Descarta registros donde nombre_pais quedo nulo tras la normalizacion JS</description>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <compare>
      <condition>
        <conditions>
</conditions>
        <function>IS NOT NULL</function>
        <leftvalue>nombre_pais</leftvalue>
        <negated>N</negated>
        <operator>-</operator>
      </condition>
    </compare>
    <send_true_to>Cargar_DIM_Pais</send_true_to>
    <attributes/>
    <GUI>
      <xloc>1248</xloc>
      <yloc>464</yloc>
    </GUI>
  </transform>
  <transform_error_handling>
  </transform_error_handling>
  <attributes/>
</pipeline>
