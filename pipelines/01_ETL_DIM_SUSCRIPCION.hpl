<?xml version="1.0" encoding="UTF-8"?>
<pipeline>
  <info>
    <name>01_ETL_DIM_SUSCRIPCION</name>
    <name_sync_with_filename>Y</name_sync_with_filename>
    <description>ETL dimension dim_suscripcion desde stg_netflix_userbase</description>
    <extended_description/>
    <pipeline_version/>
    <pipeline_type>Normal</pipeline_type>
    <parameters>
    </parameters>
    <capture_transform_performance>N</capture_transform_performance>
    <transform_performance_capturing_delay>1000</transform_performance_capturing_delay>
    <transform_performance_capturing_size_limit>100</transform_performance_capturing_size_limit>
    <created_user>-</created_user>
    <created_date>2026/06/09 00:00:00.000</created_date>
    <modified_user>-</modified_user>
    <modified_date>2026/06/09 00:00:00.000</modified_date>
  </info>
  <notepads>
  </notepads>
  <order>
    <hop>
      <from>Leer_STG_Suscripcion</from>
      <to>Sel_Campos_Suscripcion</to>
      <enabled>Y</enabled>
    </hop>
    <hop>
      <from>Sel_Campos_Suscripcion</from>
      <to>Limpiar_Strings_Suscripcion</to>
      <enabled>Y</enabled>
    </hop>
    <hop>
      <from>Limpiar_Strings_Suscripcion</from>
      <to>JS_Normalizar_Suscripcion</to>
      <enabled>Y</enabled>
    </hop>
    <hop>
      <from>JS_Normalizar_Suscripcion</from>
      <to>Sel_Campos_Final</to>
      <enabled>Y</enabled>
    </hop>
    <hop>
      <from>Sel_Campos_Final</from>
      <to>Ordenar_Suscripcion</to>
      <enabled>Y</enabled>
    </hop>
    <hop>
      <from>Ordenar_Suscripcion</from>
      <to>Eliminar_Duplicados</to>
      <enabled>Y</enabled>
    </hop>
    <hop>
      <from>Eliminar_Duplicados</from>
      <to>Validar_Tipo_Suscripcion</to>
      <enabled>Y</enabled>
    </hop>
    <hop>
      <from>Validar_Tipo_Suscripcion</from>
      <to>Cargar_DIM_Suscripcion</to>
      <enabled>Y</enabled>
    </hop>
  </order>
  <transform>
    <name>Cargar_DIM_Suscripcion</name>
    <type>InsertUpdate</type>
    <description>Upsert en dm_streaming.dim_suscripcion; id_suscripcion es SERIAL generado por la BD</description>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <commit>100</commit>
    <connection>Proyecto-Neonbd</connection>
    <lookup>
      <key>
        <condition>=</condition>
        <field>tipo_suscripcion</field>
        <name>tipo_suscripcion</name>
      </key>
      <key>
        <condition>=</condition>
        <field>duracion_plan</field>
        <name>duracion_plan</name>
      </key>
      <schema>dm_streaming</schema>
      <table>dim_suscripcion</table>
      <value>
        <name>tipo_suscripcion</name>
        <rename>tipo_suscripcion</rename>
        <update>N</update>
      </value>
      <value>
        <name>duracion_plan</name>
        <rename>duracion_plan</rename>
        <update>N</update>
      </value>
    </lookup>
    <update_bypassed>N</update_bypassed>
    <attributes/>
    <GUI>
      <xloc>720</xloc>
      <yloc>352</yloc>
    </GUI>
  </transform>
  <transform>
    <name>Eliminar_Duplicados</name>
    <type>Unique</type>
    <description>Elimina combinaciones duplicadas de tipo y duracion</description>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <count_rows>N</count_rows>
    <fields>
      <field>
        <case_insensitive>N</case_insensitive>
        <name>tipo_suscripcion</name>
      </field>
      <field>
        <case_insensitive>N</case_insensitive>
        <name>duracion_plan</name>
      </field>
    </fields>
    <reject_duplicate_row>N</reject_duplicate_row>
    <attributes/>
    <GUI>
      <xloc>352</xloc>
      <yloc>416</yloc>
    </GUI>
  </transform>
  <transform>
    <name>JS_Normalizar_Suscripcion</name>
    <type>ScriptValueMod</type>
    <description>Normaliza tipo_suscripcion a formato titulo (Basic, Standard, Premium)</description>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <optimizationLevel>9</optimizationLevel>
    <jsScripts>
      <jsScript>
        <jsScript_type>0</jsScript_type>
        <jsScript_name>Script 1</jsScript_name>
        <jsScript_script>
var tipo_suscripcion = null;
if (subscription_type != null &amp;&amp; subscription_type.trim() != '') {
  var t = subscription_type.trim();
  tipo_suscripcion = t.charAt(0).toUpperCase() + t.substring(1).toLowerCase();
}

var duracion_plan = null;
if (plan_duration != null &amp;&amp; plan_duration.trim() != '') {
  duracion_plan = plan_duration.trim();
}
        </jsScript_script>
      </jsScript>
    </jsScripts>
    <fields>
      <field>
        <name>tipo_suscripcion</name>
        <rename>tipo_suscripcion</rename>
        <type>String</type>
        <length>-1</length>
        <precision>-1</precision>
        <replace>N</replace>
      </field>
      <field>
        <name>duracion_plan</name>
        <rename>duracion_plan</rename>
        <type>String</type>
        <length>-1</length>
        <precision>-1</precision>
        <replace>N</replace>
      </field>
    </fields>
    <attributes/>
    <GUI>
      <xloc>512</xloc>
      <yloc>96</yloc>
    </GUI>
  </transform>
  <transform>
    <name>Leer_STG_Suscripcion</name>
    <type>TableInput</type>
    <description>Extrae subscription_type y plan_duration desde staging</description>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <connection>Proyecto-Neonbd</connection>
    <execute_each_row>N</execute_each_row>
    <limit>0</limit>
    <sql>SELECT subscription_type, plan_duration
FROM staging.stg_netflix_userbase
WHERE subscription_type IS NOT NULL
  AND plan_duration IS NOT NULL</sql>
    <variables_active>N</variables_active>
    <attributes/>
    <GUI>
      <xloc>96</xloc>
      <yloc>208</yloc>
    </GUI>
  </transform>
  <transform>
    <name>Limpiar_Strings_Suscripcion</name>
    <type>StringOperations</type>
    <description>Aplica trim a ambos campos para eliminar espacios sobrantes</description>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <fields>
      <field>
        <in_stream_name>subscription_type</in_stream_name>
        <out_stream_name/>
        <trim_type>both</trim_type>
        <lower_upper>none</lower_upper>
        <padding_type>none</padding_type>
        <pad_char/>
        <pad_len/>
        <init_cap>no</init_cap>
        <mask_xml>none</mask_xml>
        <digits>none</digits>
        <remove_special_characters>none</remove_special_characters>
      </field>
      <field>
        <in_stream_name>plan_duration</in_stream_name>
        <out_stream_name/>
        <trim_type>both</trim_type>
        <lower_upper>none</lower_upper>
        <padding_type>none</padding_type>
        <pad_char/>
        <pad_len/>
        <init_cap>no</init_cap>
        <mask_xml>none</mask_xml>
        <digits>none</digits>
        <remove_special_characters>none</remove_special_characters>
      </field>
    </fields>
    <attributes/>
    <GUI>
      <xloc>368</xloc>
      <yloc>192</yloc>
    </GUI>
  </transform>
  <transform>
    <name>Ordenar_Suscripcion</name>
    <type>SortRows</type>
    <description>Ordena por tipo y duracion para permitir la deduplicacion</description>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <compress>N</compress>
    <fields>
      <field>
        <ascending>Y</ascending>
        <case_sensitive>N</case_sensitive>
        <collator_enabled>N</collator_enabled>
        <collator_strength>0</collator_strength>
        <name>tipo_suscripcion</name>
        <presorted>N</presorted>
      </field>
      <field>
        <ascending>Y</ascending>
        <case_sensitive>N</case_sensitive>
        <collator_enabled>N</collator_enabled>
        <collator_strength>0</collator_strength>
        <name>duracion_plan</name>
        <presorted>N</presorted>
      </field>
    </fields>
    <sort_size>1000000</sort_size>
    <unique_rows>N</unique_rows>
    <attributes/>
    <GUI>
      <xloc>352</xloc>
      <yloc>304</yloc>
    </GUI>
  </transform>
  <transform>
    <name>Sel_Campos_Final</name>
    <type>SelectValues</type>
    <description>Conserva solo los campos normalizados generados por el JS</description>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <fields>
      <field>
        <length>-2</length>
        <name>tipo_suscripcion</name>
        <precision>-2</precision>
        <rename>tipo_suscripcion</rename>
      </field>
      <field>
        <length>-2</length>
        <name>duracion_plan</name>
        <precision>-2</precision>
        <rename>duracion_plan</rename>
      </field>
      <select_unspecified>N</select_unspecified>
    </fields>
    <attributes/>
    <GUI>
      <xloc>560</xloc>
      <yloc>224</yloc>
    </GUI>
  </transform>
  <transform>
    <name>Sel_Campos_Suscripcion</name>
    <type>SelectValues</type>
    <description>Selecciona los campos necesarios para la dimension</description>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <fields>
      <field>
        <length>-2</length>
        <name>subscription_type</name>
        <precision>-2</precision>
        <rename>subscription_type</rename>
      </field>
      <field>
        <length>-2</length>
        <name>plan_duration</name>
        <precision>-2</precision>
        <rename>plan_duration</rename>
      </field>
      <select_unspecified>N</select_unspecified>
    </fields>
    <attributes/>
    <GUI>
      <xloc>256</xloc>
      <yloc>96</yloc>
    </GUI>
  </transform>
  <transform>
    <name>Validar_Tipo_Suscripcion</name>
    <type>FilterRows</type>
    <description>Descarta registros con tipo_suscripcion nulo tras la normalizacion JS</description>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <compare>
      <condition>
        <conditions>
</conditions>
        <function>IS NOT NULL</function>
        <leftvalue>tipo_suscripcion</leftvalue>
        <negated>N</negated>
        <operator>-</operator>
      </condition>
    </compare>
    <send_true_to>Cargar_DIM_Suscripcion</send_true_to>
    <attributes/>
    <GUI>
      <xloc>512</xloc>
      <yloc>352</yloc>
    </GUI>
  </transform>
  <transform_error_handling>
  </transform_error_handling>
  <attributes/>
</pipeline>
