<?xml version="1.0" encoding="UTF-8"?>
<pipeline>
  <info>
    <name>00_LOAD_STG_NETFLIX_TITLES</name>
    <name_sync_with_filename>Y</name_sync_with_filename>
    <description>Carga staging tabla stg_netflix_titles desde NetFlix.csv</description>
    <extended_description/>
    <pipeline_version/>
    <pipeline_type>Normal</pipeline_type>
    <parameters>
    </parameters>
    <capture_transform_performance>N</capture_transform_performance>
    <transform_performance_capturing_delay>1000</transform_performance_capturing_delay>
    <transform_performance_capturing_size_limit>100</transform_performance_capturing_size_limit>
    <created_user>-</created_user>
    <created_date>2026/06/09 00:00:00.000</created_date>
    <modified_user>-</modified_user>
    <modified_date>2026/06/09 00:00:00.000</modified_date>
  </info>
  <notepads>
  </notepads>
  <order>
    <hop>
      <from>Leer_CSV_Netflix_Titles</from>
      <to>Sel_Campos_Titles</to>
      <enabled>Y</enabled>
    </hop>
    <hop>
      <from>Sel_Campos_Titles</from>
      <to>Filtrar_show_id_nulo</to>
      <enabled>Y</enabled>
    </hop>
    <hop>
      <from>Filtrar_show_id_nulo</from>
      <to>Cargar_STG_Titles</to>
      <enabled>Y</enabled>
    </hop>
  </order>
  <transform>
    <name>Leer_CSV_Netflix_Titles</name>
    <type>CSVInput</type>
    <description>Lee el archivo NetFlix.csv desde la carpeta datasets del proyecto</description>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <filename>${PROJECT_HOME}/datasets/NetFlix.csv</filename>
    <filename_field/>
    <rownum_field/>
    <include_filename>N</include_filename>
    <separator>,</separator>
    <enclosure>"</enclosure>
    <header>Y</header>
    <buffer_size>50000</buffer_size>
    <schemaDefinition/>
    <ignoreFields>N</ignoreFields>
    <lazy_conversion>N</lazy_conversion>
    <add_filename_result>N</add_filename_result>
    <parallel>N</parallel>
    <newline_possible>Y</newline_possible>
    <encoding>UTF-8</encoding>
    <fields>
      <field>
        <name>show_id</name>
        <type>String</type>
        <format/>
        <currency>$</currency>
        <decimal>.</decimal>
        <group>,</group>
        <length>10</length>
        <precision>-1</precision>
        <trim_type>both</trim_type>
      </field>
      <field>
        <name>type</name>
        <type>String</type>
        <format/>
        <currency>$</currency>
        <decimal>.</decimal>
        <group>,</group>
        <length>10</length>
        <precision>-1</precision>
        <trim_type>both</trim_type>
      </field>
      <field>
        <name>title</name>
        <type>String</type>
        <format/>
        <currency>$</currency>
        <decimal>.</decimal>
        <group>,</group>
        <length>255</length>
        <precision>-1</precision>
        <trim_type>both</trim_type>
      </field>
      <field>
        <name>director</name>
        <type>String</type>
        <format/>
        <currency>$</currency>
        <decimal>.</decimal>
        <group>,</group>
        <length>255</length>
        <precision>-1</precision>
        <trim_type>both</trim_type>
      </field>
      <field>
        <name>cast</name>
        <type>String</type>
        <format/>
        <currency>$</currency>
        <decimal>.</decimal>
        <group>,</group>
        <length>2000</length>
        <precision>-1</precision>
        <trim_type>both</trim_type>
      </field>
      <field>
        <name>country</name>
        <type>String</type>
        <format/>
        <currency>$</currency>
        <decimal>.</decimal>
        <group>,</group>
        <length>255</length>
        <precision>-1</precision>
        <trim_type>both</trim_type>
      </field>
      <field>
        <name>date_added</name>
        <type>String</type>
        <format/>
        <currency>$</currency>
        <decimal>.</decimal>
        <group>,</group>
        <length>20</length>
        <precision>-1</precision>
        <trim_type>both</trim_type>
      </field>
      <field>
        <name>release_year</name>
        <type>String</type>
        <format/>
        <currency>$</currency>
        <decimal>.</decimal>
        <group>,</group>
        <length>4</length>
        <precision>-1</precision>
        <trim_type>both</trim_type>
      </field>
      <field>
        <name>rating</name>
        <type>String</type>
        <format/>
        <currency>$</currency>
        <decimal>.</decimal>
        <group>,</group>
        <length>10</length>
        <precision>-1</precision>
        <trim_type>both</trim_type>
      </field>
      <field>
        <name>duration</name>
        <type>String</type>
        <format/>
        <currency>$</currency>
        <decimal>.</decimal>
        <group>,</group>
        <length>10</length>
        <precision>-1</precision>
        <trim_type>both</trim_type>
      </field>
      <field>
        <name>genres</name>
        <type>String</type>
        <format/>
        <currency>$</currency>
        <decimal>.</decimal>
        <group>,</group>
        <length>255</length>
        <precision>-1</precision>
        <trim_type>both</trim_type>
      </field>
      <field>
        <name>description</name>
        <type>String</type>
        <format/>
        <currency>$</currency>
        <decimal>.</decimal>
        <group>,</group>
        <length>2000</length>
        <precision>-1</precision>
        <trim_type>both</trim_type>
      </field>
    </fields>
    <attributes/>
    <GUI>
      <xloc>160</xloc>
      <yloc>208</yloc>
    </GUI>
  </transform>
  <transform>
    <name>Sel_Campos_Titles</name>
    <type>SelectValues</type>
    <description>Selecciona campos y renombra cast a elenco</description>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <fields>
      <field>
        <length>-2</length>
        <name>show_id</name>
        <precision>-2</precision>
        <rename>show_id</rename>
      </field>
      <field>
        <length>-2</length>
        <name>type</name>
        <precision>-2</precision>
        <rename>type</rename>
      </field>
      <field>
        <length>-2</length>
        <name>title</name>
        <precision>-2</precision>
        <rename>title</rename>
      </field>
      <field>
        <length>-2</length>
        <name>director</name>
        <precision>-2</precision>
        <rename>director</rename>
      </field>
      <field>
        <length>-2</length>
        <name>cast</name>
        <precision>-2</precision>
        <rename>elenco</rename>
      </field>
      <field>
        <length>-2</length>
        <name>country</name>
        <precision>-2</precision>
        <rename>country</rename>
      </field>
      <field>
        <length>-2</length>
        <name>date_added</name>
        <precision>-2</precision>
        <rename>date_added</rename>
      </field>
      <field>
        <length>-2</length>
        <name>release_year</name>
        <precision>-2</precision>
        <rename>release_year</rename>
      </field>
      <field>
        <length>-2</length>
        <name>rating</name>
        <precision>-2</precision>
        <rename>rating</rename>
      </field>
      <field>
        <length>-2</length>
        <name>duration</name>
        <precision>-2</precision>
        <rename>duration</rename>
      </field>
      <field>
        <length>-2</length>
        <name>genres</name>
        <precision>-2</precision>
        <rename>genres</rename>
      </field>
      <field>
        <length>-2</length>
        <name>description</name>
        <precision>-2</precision>
        <rename>description</rename>
      </field>
      <select_unspecified>N</select_unspecified>
    </fields>
    <attributes/>
    <GUI>
      <xloc>352</xloc>
      <yloc>208</yloc>
    </GUI>
  </transform>
  <transform>
    <name>Filtrar_show_id_nulo</name>
    <type>FilterRows</type>
    <description>Descarta registros donde show_id es nulo</description>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <compare>
      <condition>
        <conditions>
</conditions>
        <function>IS NOT NULL</function>
        <leftvalue>show_id</leftvalue>
        <negated>N</negated>
        <operator>-</operator>
      </condition>
    </compare>
    <send_true_to>Cargar_STG_Titles</send_true_to>
    <attributes/>
    <GUI>
      <xloc>544</xloc>
      <yloc>208</yloc>
    </GUI>
  </transform>
  <transform>
    <name>Cargar_STG_Titles</name>
    <type>TableOutput</type>
    <description>Trunca e inserta en batch en staging.stg_netflix_titles</description>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <connection>Proyecto-Neonbd</connection>
    <schema>staging</schema>
    <table>stg_netflix_titles</table>
    <commit>1000</commit>
    <truncate>Y</truncate>
    <truncate_schema>N</truncate_schema>
    <ignore_errors>N</ignore_errors>
    <use_batch>Y</use_batch>
    <specify_fields>Y</specify_fields>
    <return_keys>N</return_keys>
    <return_field/>
    <fields>
      <field>
        <column_name>show_id</column_name>
        <stream_name>show_id</stream_name>
      </field>
      <field>
        <column_name>type</column_name>
        <stream_name>type</stream_name>
      </field>
      <field>
        <column_name>title</column_name>
        <stream_name>title</stream_name>
      </field>
      <field>
        <column_name>director</column_name>
        <stream_name>director</stream_name>
      </field>
      <field>
        <column_name>elenco</column_name>
        <stream_name>elenco</stream_name>
      </field>
      <field>
        <column_name>country</column_name>
        <stream_name>country</stream_name>
      </field>
      <field>
        <column_name>date_added</column_name>
        <stream_name>date_added</stream_name>
      </field>
      <field>
        <column_name>release_year</column_name>
        <stream_name>release_year</stream_name>
      </field>
      <field>
        <column_name>rating</column_name>
        <stream_name>rating</stream_name>
      </field>
      <field>
        <column_name>duration</column_name>
        <stream_name>duration</stream_name>
      </field>
      <field>
        <column_name>genres</column_name>
        <stream_name>genres</stream_name>
      </field>
      <field>
        <column_name>description</column_name>
        <stream_name>description</stream_name>
      </field>
    </fields>
    <attributes/>
    <GUI>
      <xloc>736</xloc>
      <yloc>208</yloc>
    </GUI>
  </transform>
  <transform_error_handling>
  </transform_error_handling>
  <attributes/>
</pipeline>
