<?xml version="1.0" encoding="UTF-8"?>
<pipeline>
  <info>
    <name>00_LOAD_STG_NETFLIX_USERBASE</name>
    <name_sync_with_filename>Y</name_sync_with_filename>
    <description>Carga staging tabla stg_netflix_userbase desde Netflix Userbase.csv</description>
    <extended_description/>
    <pipeline_version/>
    <pipeline_type>Normal</pipeline_type>
    <parameters>
    </parameters>
    <capture_transform_performance>N</capture_transform_performance>
    <transform_performance_capturing_delay>1000</transform_performance_capturing_delay>
    <transform_performance_capturing_size_limit>100</transform_performance_capturing_size_limit>
    <created_user>-</created_user>
    <created_date>2026/06/09 00:00:00.000</created_date>
    <modified_user>-</modified_user>
    <modified_date>2026/06/09 00:00:00.000</modified_date>
  </info>
  <notepads>
  </notepads>
  <order>
    <hop>
      <from>Leer_CSV_Netflix_Userbase</from>
      <to>Sel_Campos_Userbase</to>
      <enabled>Y</enabled>
    </hop>
    <hop>
      <from>Sel_Campos_Userbase</from>
      <to>Filtrar_user_id_nulo</to>
      <enabled>Y</enabled>
    </hop>
    <hop>
      <from>Filtrar_user_id_nulo</from>
      <to>Cargar_STG_Userbase</to>
      <enabled>Y</enabled>
    </hop>
  </order>
  <transform>
    <name>Leer_CSV_Netflix_Userbase</name>
    <type>CSVInput</type>
    <description>Lee el archivo Netflix Userbase.csv desde la carpeta datasets del proyecto</description>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <filename>${PROJECT_HOME}/datasets/Netflix Userbase.csv</filename>
    <filename_field/>
    <rownum_field/>
    <include_filename>N</include_filename>
    <separator>,</separator>
    <enclosure>"</enclosure>
    <header>Y</header>
    <buffer_size>50000</buffer_size>
    <schemaDefinition/>
    <ignoreFields>N</ignoreFields>
    <lazy_conversion>N</lazy_conversion>
    <add_filename_result>N</add_filename_result>
    <parallel>N</parallel>
    <newline_possible>N</newline_possible>
    <encoding>UTF-8</encoding>
    <fields>
      <field>
        <name>User ID</name>
        <type>String</type>
        <format/>
        <currency>$</currency>
        <decimal>.</decimal>
        <group>,</group>
        <length>10</length>
        <precision>-1</precision>
        <trim_type>both</trim_type>
      </field>
      <field>
        <name>Subscription Type</name>
        <type>String</type>
        <format/>
        <currency>$</currency>
        <decimal>.</decimal>
        <group>,</group>
        <length>20</length>
        <precision>-1</precision>
        <trim_type>both</trim_type>
      </field>
      <field>
        <name>Monthly Revenue</name>
        <type>String</type>
        <format/>
        <currency>$</currency>
        <decimal>.</decimal>
        <group>,</group>
        <length>5</length>
        <precision>-1</precision>
        <trim_type>both</trim_type>
      </field>
      <field>
        <name>Join Date</name>
        <type>String</type>
        <format/>
        <currency>$</currency>
        <decimal>.</decimal>
        <group>,</group>
        <length>10</length>
        <precision>-1</precision>
        <trim_type>both</trim_type>
      </field>
      <field>
        <name>Last Payment Date</name>
        <type>String</type>
        <format/>
        <currency>$</currency>
        <decimal>.</decimal>
        <group>,</group>
        <length>10</length>
        <precision>-1</precision>
        <trim_type>both</trim_type>
      </field>
      <field>
        <name>Country</name>
        <type>String</type>
        <format/>
        <currency>$</currency>
        <decimal>.</decimal>
        <group>,</group>
        <length>50</length>
        <precision>-1</precision>
        <trim_type>both</trim_type>
      </field>
      <field>
        <name>Age</name>
        <type>String</type>
        <format/>
        <currency>$</currency>
        <decimal>.</decimal>
        <group>,</group>
        <length>3</length>
        <precision>-1</precision>
        <trim_type>both</trim_type>
      </field>
      <field>
        <name>Gender</name>
        <type>String</type>
        <format/>
        <currency>$</currency>
        <decimal>.</decimal>
        <group>,</group>
        <length>10</length>
        <precision>-1</precision>
        <trim_type>both</trim_type>
      </field>
      <field>
        <name>Device</name>
        <type>String</type>
        <format/>
        <currency>$</currency>
        <decimal>.</decimal>
        <group>,</group>
        <length>20</length>
        <precision>-1</precision>
        <trim_type>both</trim_type>
      </field>
      <field>
        <name>Plan Duration</name>
        <type>String</type>
        <format/>
        <currency>$</currency>
        <decimal>.</decimal>
        <group>,</group>
        <length>20</length>
        <precision>-1</precision>
        <trim_type>both</trim_type>
      </field>
    </fields>
    <attributes/>
    <GUI>
      <xloc>160</xloc>
      <yloc>208</yloc>
    </GUI>
  </transform>
  <transform>
    <name>Sel_Campos_Userbase</name>
    <type>SelectValues</type>
    <description>Renombra columnas del CSV a los nombres de la tabla staging</description>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <fields>
      <field>
        <length>-2</length>
        <name>User ID</name>
        <precision>-2</precision>
        <rename>user_id</rename>
      </field>
      <field>
        <length>-2</length>
        <name>Subscription Type</name>
        <precision>-2</precision>
        <rename>subscription_type</rename>
      </field>
      <field>
        <length>-2</length>
        <name>Monthly Revenue</name>
        <precision>-2</precision>
        <rename>monthly_revenue</rename>
      </field>
      <field>
        <length>-2</length>
        <name>Join Date</name>
        <precision>-2</precision>
        <rename>join_date</rename>
      </field>
      <field>
        <length>-2</length>
        <name>Last Payment Date</name>
        <precision>-2</precision>
        <rename>last_payment_date</rename>
      </field>
      <field>
        <length>-2</length>
        <name>Country</name>
        <precision>-2</precision>
        <rename>country</rename>
      </field>
      <field>
        <length>-2</length>
        <name>Age</name>
        <precision>-2</precision>
        <rename>age</rename>
      </field>
      <field>
        <length>-2</length>
        <name>Gender</name>
        <precision>-2</precision>
        <rename>gender</rename>
      </field>
      <field>
        <length>-2</length>
        <name>Device</name>
        <precision>-2</precision>
        <rename>device</rename>
      </field>
      <field>
        <length>-2</length>
        <name>Plan Duration</name>
        <precision>-2</precision>
        <rename>plan_duration</rename>
      </field>
      <select_unspecified>N</select_unspecified>
    </fields>
    <attributes/>
    <GUI>
      <xloc>352</xloc>
      <yloc>208</yloc>
    </GUI>
  </transform>
  <transform>
    <name>Filtrar_user_id_nulo</name>
    <type>FilterRows</type>
    <description>Descarta registros donde user_id es nulo</description>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <compare>
      <condition>
        <conditions>
</conditions>
        <function>IS NOT NULL</function>
        <leftvalue>user_id</leftvalue>
        <negated>N</negated>
        <operator>-</operator>
      </condition>
    </compare>
    <send_true_to>Cargar_STG_Userbase</send_true_to>
    <attributes/>
    <GUI>
      <xloc>544</xloc>
      <yloc>208</yloc>
    </GUI>
  </transform>
  <transform>
    <name>Cargar_STG_Userbase</name>
    <type>TableOutput</type>
    <description>Trunca e inserta en batch en staging.stg_netflix_userbase</description>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <connection>Proyecto-Neonbd</connection>
    <schema>staging</schema>
    <table>stg_netflix_userbase</table>
    <commit>1000</commit>
    <truncate>Y</truncate>
    <truncate_schema>N</truncate_schema>
    <ignore_errors>N</ignore_errors>
    <use_batch>Y</use_batch>
    <specify_fields>Y</specify_fields>
    <return_keys>N</return_keys>
    <return_field/>
    <fields>
      <field>
        <column_name>user_id</column_name>
        <stream_name>user_id</stream_name>
      </field>
      <field>
        <column_name>subscription_type</column_name>
        <stream_name>subscription_type</stream_name>
      </field>
      <field>
        <column_name>monthly_revenue</column_name>
        <stream_name>monthly_revenue</stream_name>
      </field>
      <field>
        <column_name>join_date</column_name>
        <stream_name>join_date</stream_name>
      </field>
      <field>
        <column_name>last_payment_date</column_name>
        <stream_name>last_payment_date</stream_name>
      </field>
      <field>
        <column_name>country</column_name>
        <stream_name>country</stream_name>
      </field>
      <field>
        <column_name>age</column_name>
        <stream_name>age</stream_name>
      </field>
      <field>
        <column_name>gender</column_name>
        <stream_name>gender</stream_name>
      </field>
      <field>
        <column_name>device</column_name>
        <stream_name>device</stream_name>
      </field>
      <field>
        <column_name>plan_duration</column_name>
        <stream_name>plan_duration</stream_name>
      </field>
    </fields>
    <attributes/>
    <GUI>
      <xloc>736</xloc>
      <yloc>208</yloc>
    </GUI>
  </transform>
  <transform_error_handling>
  </transform_error_handling>
  <attributes/>
</pipeline>
