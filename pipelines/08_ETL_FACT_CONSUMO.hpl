  <transform>
    <name>LEER_CONSUMO_SIMULADO_DESDE_STAGING_CON_DIMENSIONES</name>
    <type>TableInput</type>
    <description/>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <connection>Proyecto-Neonbd</connection>
    <execute_each_row>N</execute_each_row>
    <limit>0</limit>
    <sql>WITH contenidos_ordenados AS (
    SELECT
        dc.id_contenido,
        ROW_NUMBER() OVER (ORDER BY dc.id_contenido) AS rn,
        COUNT(*) OVER () AS total_contenidos
    FROM dm_streaming.dim_contenido dc
),
usuarios_base AS (
    SELECT
        ub."User ID"::integer AS id_usuario_origen,
        ub.country AS pais_usuario,
        ub."Last Payment Date"::date AS fecha_consumo_simulada,
        ((ub."User ID"::integer - 1) % 5) + 1 AS cantidad_visualizaciones
    FROM staging.stg_netflix_userbase ub
)
SELECT
    u.id_usuario,
    c.id_contenido,
    p.id_pais,
    t.id_tiempo,
    ub.cantidad_visualizaciones
FROM usuarios_base ub
LEFT JOIN dm_streaming.dim_usuario u
    ON u.id_usuario = ub.id_usuario_origen
LEFT JOIN contenidos_ordenados c
    ON c.rn = ((ub.id_usuario_origen - 1) % c.total_contenidos) + 1
LEFT JOIN dm_streaming.dim_pais p
    ON p.nombre_pais = TRIM(ub.pais_usuario)
LEFT JOIN dm_streaming.dim_tiempo t
    ON t.fecha_completa = ub.fecha_consumo_simulada;</sql>
    <variables_active>N</variables_active>
    <attributes/>
    <GUI>
      <xloc>512</xloc>
      <yloc>48</yloc>
    </GUI>
  </transform>
