        <negated>N</negated>
        <operator>-</operator>
      </condition>
    </compare>
    <send_true_to>SL_Buscar_id_pais</send_true_to>
    <attributes/>
    <GUI>
      <xloc>1056</xloc>
      <yloc>624</yloc>
    </GUI>
  </transform>
  <transform>
    <name>JS_Preparar_Consumo</name>
    <type>ScriptValueMod</type>
    <description>Convierte user_id a Integer, normaliza country a proper case, parsea join_date a Date y fija cantidad_visualizaciones a 1</description>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <optimizationLevel>9</optimizationLevel>
    <jsScripts>
      <jsScript>
        <jsScript_type>0</jsScript_type>
        <jsScript_name>Script 1</jsScript_name>
        <jsScript_script>
// Convert user_id String to Integer
var id_usuario = null;
if (user_id != null &amp;&amp; user_id.trim() != '') {
  var parsedId = parseInt(user_id.trim(), 10);
  if (!isNaN(parsedId) &amp;&amp; parsedId > 0) {
    id_usuario = parsedId;
  }
}

// show_id is already the id_contenido; pass through trimmed
var id_contenido = (show_id != null) ? show_id.trim() : null;

// Normalize country to proper case word by word
var nombre_pais_norm = 'Sin dato';
if (country != null &amp;&amp; country.trim() != '' &amp;&amp; country.trim() != 'Sin dato') {
  var cWords = country.trim().split(' ');
  var cResult = [];
  for (var i = 0; i &lt; cWords.length; i++) {
    if (cWords[i].length > 0) {
      cResult.push(cWords[i].charAt(0).toUpperCase() + cWords[i].substring(1).toLowerCase());
    }
  }
  nombre_pais_norm = cResult.join(' ');
}

// Parse join_date DD-MM-YY to Date
var fecha_consumo = null;
if (join_date != null &amp;&amp; join_date.trim() != '' &amp;&amp; join_date.trim() != 'Sin dato') {
  var parts = join_date.trim().split('-');
  if (parts.length == 3) {
    var d = parseInt(parts[0], 10);
    var m = parseInt(parts[1], 10);
    var y_raw = parseInt(parts[2], 10);
    var y = y_raw &lt; 100 ? 2000 + y_raw : y_raw;
    if (!isNaN(d) &amp;&amp; !isNaN(m) &amp;&amp; !isNaN(y) &amp;&amp; d >= 1 &amp;&amp; d &lt;= 31 &amp;&amp; m >= 1 &amp;&amp; m &lt;= 12) {
      var cal = java.util.Calendar.getInstance();
      cal.set(y, m - 1, d, 0, 0, 0);
      cal.set(java.util.Calendar.MILLISECOND, 0);
      fecha_consumo = cal.getTime();
    }
  }
}

// Each derived consumption record counts as 1 visualization
var cantidad_visualizaciones = 1;
        </jsScript_script>
      </jsScript>
    </jsScripts>
    <fields>
      <field>
        <name>id_usuario</name>
        <rename>id_usuario</rename>
        <type>Integer</type>
        <length>-1</length>
