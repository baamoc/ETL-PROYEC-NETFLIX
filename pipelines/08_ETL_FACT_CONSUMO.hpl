  <transform>
    <name>Leer_STG_Consumo</name>
    <type>TableInput</type>
    <description>Cruza userbase con titles por pais del usuario para derivar consumos; limitado a 5000 registros para el demo</description>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <connection>Proyecto-Neonbd</connection>
    <execute_each_row>N</execute_each_row>
    <limit>0</limit>
    <sql>SELECT u.user_id, c.show_id, u.country, u.join_date
FROM staging.stg_netflix_userbase u
INNER JOIN staging.stg_netflix_titles c
    ON LOWER(TRIM(c.country)) LIKE '%' || LOWER(TRIM(u.country)) || '%'
WHERE u.user_id IS NOT NULL
  AND u.country IS NOT NULL
  AND c.show_id IS NOT NULL
  AND c.country IS NOT NULL
ORDER BY u.user_id, c.show_id
LIMIT 5000</sql>
    <variables_active>N</variables_active>
    <attributes/>
    <GUI>
      <xloc>288</xloc>
      <yloc>144</yloc>
    </GUI>
  </transform>
