<?xml version="1.0" encoding="UTF-8"?>
<pipeline>
  <info>
    <name>04_ETL_DIM_TIEMPO</name>
    <name_sync_with_filename>Y</name_sync_with_filename>
    <description>ETL dimension dim_tiempo; une fechas de userbase (DD-MM-YY) y titles (DD-Mon-YY)</description>
