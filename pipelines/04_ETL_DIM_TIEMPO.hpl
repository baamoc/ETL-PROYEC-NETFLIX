    <execute_each_row>N</execute_each_row>
    <limit>0</limit>
    <sql>SELECT fecha_completa FROM dm_streaming.dim_tiempo</sql>
    <variables_active>N</variables_active>
    <attributes/>
    <GUI>
      <xloc>832</xloc>
      <yloc>512</yloc>
    </GUI>
  </transform>
  <transform>
    <name>SL_Verificar_Existente</name>
    <type>StreamLookup</type>
    <description>Verifica si fecha_completa ya existe en dim_tiempo; null en fecha_existe significa fecha nueva</description>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <from>Leer_DIM_Existente</from>
    <input_sorted>N</input_sorted>
    <preserve_memory>N</preserve_memory>
    <sorted_list>N</sorted_list>
    <integer_pair>N</integer_pair>
    <lookup>
      <key>
        <name>fecha_completa</name>
        <field>fecha_completa</field>
      </key>
      <value>
        <name>fecha_completa</name>
        <rename>fecha_existe</rename>
        <default/>
        <type>Date</type>
      </value>
    </lookup>
    <attributes/>
    <GUI>
      <xloc>992</xloc>
      <yloc>368</yloc>
    </GUI>
  </transform>
  <transform>
    <name>Filtrar_Nuevos</name>
    <type>FilterRows</type>
    <description>Solo pasan fechas nuevas (fecha_existe IS NULL); las ya cargadas se descartan sin error</description>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <compare>
      <condition>
        <conditions>
</conditions>
        <function>IS NULL</function>
