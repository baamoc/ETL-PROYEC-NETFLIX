  <transform>
    <name>Leer_fechas_desde_staging</name>
    <type>TableInput</type>
    <description/>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <connection>Proyecto-Neonbd</connection>
    <execute_each_row>N</execute_each_row>
    <limit>0</limit>
    <sql>WITH fechas_origen AS (
    SELECT "Join Date"::date AS fecha_completa
    FROM staging.stg_netflix_userbase
    WHERE "Join Date" IS NOT NULL

    UNION

    SELECT "Last Payment Date"::date AS fecha_completa
    FROM staging.stg_netflix_userbase
    WHERE "Last Payment Date" IS NOT NULL

    UNION

    SELECT
        CASE
            WHEN TRIM(date_added) ~ '^[0-9]{1,2}-[A-Za-z]{3}-[0-9]{2}$'
                THEN TO_DATE(TRIM(date_added), 'DD-Mon-YY')::date

            WHEN TRIM(date_added) ~ '^[A-Za-z]+ [0-9]{1,2}, [0-9]{4}$'
                THEN TO_DATE(TRIM(date_added), 'Month DD, YYYY')::date
        END AS fecha_completa
    FROM staging.stg_netflix_titles
    WHERE date_added IS NOT NULL
      AND TRIM(date_added) &lt;&gt; ''
      AND (
            TRIM(date_added) ~ '^[0-9]{1,2}-[A-Za-z]{3}-[0-9]{2}$'
         OR TRIM(date_added) ~ '^[A-Za-z]+ [0-9]{1,2}, [0-9]{4}$'
      )
),
fechas_preparadas AS (
    SELECT DISTINCT fecha_completa
    FROM fechas_origen
    WHERE fecha_completa IS NOT NULL
)
SELECT
    fp.fecha_completa,
    EXTRACT(DAY FROM fp.fecha_completa)::int AS dia,
    EXTRACT(MONTH FROM fp.fecha_completa)::int AS mes,
    EXTRACT(YEAR FROM fp.fecha_completa)::int AS anio
FROM fechas_preparadas fp
WHERE NOT EXISTS (
    SELECT 1
    FROM dm_streaming.dim_tiempo dt
    WHERE dt.fecha_completa = fp.fecha_completa
)
ORDER BY fp.fecha_completa;</sql>
    <variables_active>N</variables_active>
    <attributes/>
    <GUI>
      <xloc>160</xloc>
      <yloc>144</yloc>
    </GUI>
  </transform>
