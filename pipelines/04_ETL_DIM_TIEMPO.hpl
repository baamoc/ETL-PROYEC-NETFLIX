      </condition>
    </compare>
    <send_true_to>SL_Verificar_Existente</send_true_to>
    <attributes/>
    <GUI>
      <xloc>672</xloc>
      <yloc>368</yloc>
    </GUI>
  </transform>
  <transform_error_handling>
