    <send_true_to>Cargar_DIM_Tiempo</send_true_to>
    <attributes/>
    <GUI>
      <xloc>1152</xloc>
      <yloc>368</yloc>
    </GUI>
  </transform>
  <transform>
    <name>Cargar_DIM_Tiempo</name>
    <type>TableOutput</type>
    <description>INSERT masivo en dm_streaming.dim_tiempo; solo llegan fechas nuevas del StreamLookup</description>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <connection>Proyecto-Neonbd</connection>
    <schema>dm_streaming</schema>
    <table>dim_tiempo</table>
    <commit>1000</commit>
    <truncate>N</truncate>
    <ignore_errors>N</ignore_errors>
    <use_batch>Y</use_batch>
    <specify_fields>Y</specify_fields>
    <fields>
      <field>
        <column_name>fecha_completa</column_name>
        <stream_name>fecha_completa</stream_name>
      </field>
      <field>
        <column_name>dia</column_name>
        <stream_name>dia</stream_name>
      </field>
      <field>
        <column_name>mes</column_name>
        <stream_name>mes</stream_name>
      </field>
      <field>
        <column_name>anio</column_name>
        <stream_name>anio</stream_name>
      </field>
    </fields>
    <attributes/>
    <GUI>
      <xloc>1312</xloc>
      <yloc>368</yloc>
    </GUI>
  </transform>
  <transform>
    <name>Corregir_Fecha</name>
    <type>ReplaceString</type>
    <description>Reemplaza strings vacios en fecha_raw por Sin dato para identificarlos en el JS</description>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <fields>
      <field>
        <case_sensitive>Y</case_sensitive>
        <in_stream_name>fecha_raw</in_stream_name>
        <is_unicode>N</is_unicode>
        <replace_by_string>Sin dato</replace_by_string>
        <replace_string>^\s*$</replace_string>
        <set_empty_string>N</set_empty_string>
        <use_regex>Y</use_regex>
        <whole_word>N</whole_word>
      </field>
    </fields>
    <attributes/>
    <GUI>
      <xloc>528</xloc>
      <yloc>112</yloc>
    </GUI>
  </transform>
  <transform>
    <name>Eliminar_Duplicados</name>
    <type>Unique</type>
    <description>Elimina fechas duplicadas; requiere stream ordenado por fecha_completa</description>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <count_rows>N</count_rows>
    <fields>
      <field>
        <case_insensitive>N</case_insensitive>
        <name>fecha_completa</name>
      </field>
    </fields>
    <reject_duplicate_row>N</reject_duplicate_row>
    <attributes/>
    <GUI>
      <xloc>512</xloc>
      <yloc>368</yloc>
    </GUI>
  </transform>
  <transform>
    <name>JS_Parsear_Fecha</name>
    <type>ScriptValueMod</type>
    <description>Detecta formato DD-MM-YY o DD-Mon-YY y parsea a fecha_completa (Date), dia, mes, anio (Integer)</description>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <optimizationLevel>9</optimizationLevel>
    <jsScripts>
      <jsScript>
        <jsScript_type>0</jsScript_type>
        <jsScript_name>Script 1</jsScript_name>
        <jsScript_script>
var months_map = {
  'Jan': 1, 'Feb': 2, 'Mar': 3, 'Apr': 4,
  'May': 5, 'Jun': 6, 'Jul': 7, 'Aug': 8,
  'Sep': 9, 'Oct': 10, 'Nov': 11, 'Dec': 12
};

var fecha_completa = null;
var dia = null;
var mes = null;
var anio = null;

if (fecha_raw != null &amp;&amp; fecha_raw.trim() != '' &amp;&amp; fecha_raw.trim() != 'Sin dato') {
  var parts = fecha_raw.trim().split('-');
  if (parts.length == 3) {
    var d = parseInt(parts[0], 10);
    var m_raw = parts[1].trim();
    var y_raw = parseInt(parts[2], 10);

    var m;
    if (isNaN(parseInt(m_raw, 10))) {
      // DD-Mon-YY format (e.g. "14-Aug-20")
      var cap = m_raw.charAt(0).toUpperCase() + m_raw.substring(1).toLowerCase();
      m = months_map[cap] || null;
    } else {
      // DD-MM-YY format (e.g. "15-01-22")
      m = parseInt(m_raw, 10);
    }

    // 2-digit year -> 20xx
    var y = y_raw &lt; 100 ? 2000 + y_raw : y_raw;

    if (!isNaN(d) &amp;&amp; m != null &amp;&amp; !isNaN(y) &amp;&amp; d >= 1 &amp;&amp; d &lt;= 31 &amp;&amp; m >= 1 &amp;&amp; m &lt;= 12) {
      dia = d;
      mes = m;
      anio = y;
      var cal = java.util.Calendar.getInstance();
      cal.set(y, m - 1, d, 0, 0, 0);
      cal.set(java.util.Calendar.MILLISECOND, 0);
      fecha_completa = cal.getTime();
    }
  }
}
        </jsScript_script>
      </jsScript>
    </jsScripts>
    <fields>
      <field>
        <name>fecha_completa</name>
        <rename>fecha_completa</rename>
        <type>Date</type>
        <length>-1</length>
        <precision>-1</precision>
        <replace>N</replace>
      </field>
      <field>
        <name>dia</name>
        <rename>dia</rename>
        <type>Integer</type>
        <length>-1</length>
        <precision>-1</precision>
        <replace>N</replace>
      </field>
      <field>
        <name>mes</name>
        <rename>mes</rename>
        <type>Integer</type>
        <length>-1</length>
        <precision>-1</precision>
        <replace>N</replace>
      </field>
      <field>
        <name>anio</name>
        <rename>anio</rename>
        <type>Integer</type>
        <length>-1</length>
        <precision>-1</precision>
        <replace>N</replace>
      </field>
    </fields>
    <attributes/>
    <GUI>
      <xloc>512</xloc>
      <yloc>240</yloc>
    </GUI>
  </transform>
  <transform>
    <name>Leer_Todas_Fechas</name>
    <type>TableInput</type>
    <description>Extrae todas las fechas en un solo stream: join_date y last_payment_date de userbase, date_added de titles</description>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <connection>Proyecto-Neonbd</connection>
    <execute_each_row>N</execute_each_row>
    <limit>0</limit>
    <sql>SELECT join_date AS fecha_raw
FROM staging.stg_netflix_userbase
WHERE join_date IS NOT NULL
UNION ALL
SELECT last_payment_date AS fecha_raw
FROM staging.stg_netflix_userbase
WHERE last_payment_date IS NOT NULL
UNION ALL
SELECT date_added AS fecha_raw
FROM staging.stg_netflix_titles
WHERE date_added IS NOT NULL</sql>
    <variables_active>N</variables_active>
    <attributes/>
    <GUI>
      <xloc>240</xloc>
      <yloc>224</yloc>
    </GUI>
  </transform>
  <transform>
