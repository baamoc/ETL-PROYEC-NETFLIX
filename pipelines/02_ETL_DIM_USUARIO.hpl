  <transform>
    <name>JS_Convertir_Usuario</name>
    <type>ScriptValueMod</type>
    <description>Convierte user_id y age de String a Integer; normaliza genero a formato titulo</description>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <optimizationLevel>9</optimizationLevel>
    <jsScripts>
      <jsScript>
        <jsScript_type>0</jsScript_type>
        <jsScript_name>Script 1</jsScript_name>
        <jsScript_script>
// Convert user_id String to Integer
var id_usuario = null;
if (user_id != null &amp;&amp; user_id.trim() != '') {
  var parsedId = parseInt(user_id.trim(), 10);
  if (!isNaN(parsedId) &amp;&amp; parsedId > 0) {
    id_usuario = parsedId;
  }
}

// Convert age String to Integer with range validation
var edad = null;
if (age != null &amp;&amp; age.trim() != '') {
  var parsedAge = parseInt(age.trim(), 10);
  if (!isNaN(parsedAge) &amp;&amp; parsedAge > 0 &amp;&amp; parsedAge &lt; 150) {
    edad = parsedAge;
  }
}

// Normalize gender to proper case (Male, Female)
var genero = 'Sin dato';
if (gender != null &amp;&amp; gender.trim() != '' &amp;&amp; gender.trim() != 'Sin dato') {
  var g = gender.trim();
  genero = g.charAt(0).toUpperCase() + g.substring(1).toLowerCase();
}
        </jsScript_script>
      </jsScript>
    </jsScripts>
    <fields>
      <field>
        <name>id_usuario</name>
        <rename>id_usuario</rename>
        <type>Integer</type>
        <length>-1</length>
