  <transform>
    <name>JS_fecha</name>
    <type>ScriptValueMod</type>
    <description/>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <optimizationLevel>9</optimizationLevel>
    <jsScripts>
      <jsScript>
        <jsScript_type>0</jsScript_type>
        <jsScript_name>Script 1</jsScript_name>
        <jsScript_script>//Script here

var mes=0;
var desc_mes=null;

switch(abr_mes.toString()){
    case "Jan":
        mes=1;
        desc_mes="Enero";
        break;
    case "Feb":
        mes=2;
        desc_mes="Febrero";
        break;
    case "Mar":
        mes=3;
        desc_mes="Marzo";
        break;
    case "Apr":
        mes=4;
        desc_mes="Abril";
        break;
    case "May":
        mes=5;
        desc_mes="Mayo";
        break;
    case "Jun":
        mes=6;
        desc_mes="Junio";
        break;
    case "Jul":
        mes=7;
        desc_mes="Julio";
        break;
    case "Aug":
        mes=8;
        desc_mes="Agosto";
        break;
    case "Sep":
        mes=9;
        desc_mes="Septiembre";
        break;
    case "Oct":
        mes=10;
        desc_mes="Octubre";
        break;
    case "Nov":
        mes=11;
        desc_mes="Noviembre";
        break;
    case "Dec":
        mes=12;
        desc_mes="Diciembre";
        break;
    default:
        mes:100;
        desc_mes="Mes no encontrado";
        break;
}
var semana = week(new Date(año,mes-1,dia-1));

var desc_dia = null;
var dow=new Date(año,mes-1,dia-1).getDay();

switch(dow){
case 0:
desc_dia="Lunes";
break;
case 1:
desc_dia="Martes";
break;
case 2:
desc_dia="Miercoles";
break;
case 3:
desc_dia="Jueves";
break;
case 4:
desc_dia="viernes";
break;
case 5:
desc_dia="Sabado";
break;
case 6:
desc_dia="Domingo";
}
</jsScript_script>
      </jsScript>
    </jsScripts>
