    <name>JS_SO</name>
    <type>ScriptValueMod</type>
    <description/>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <optimizationLevel>9</optimizationLevel>
    <jsScripts>
      <jsScript>
        <jsScript_type>0</jsScript_type>
        <jsScript_name>Script 1</jsScript_name>
        <jsScript_script>var nombreSO = 'Sin Definir';
var versionSO = 'Sin Definir';
var familiaSO = 'Sin Definir';

if (os_navegador != null &amp;&amp; os_navegador != '') {

    var regexNombre = /(Windows NT|Linux|Mac OS X|Android|iPhone|X11)[\/\s;]*([0-9._]+)?/i;
    var matchNombre = os_navegador.match(regexNombre);

    var regexFamilia = /(WOW64|Win64|x64|Mobile|rv:[0-9.]+)/i;
    var matchFamilia = os_navegador.match(regexFamilia);

    if (matchNombre) {
        nombreSO = matchNombre[1] ? matchNombre[1] : 'Sin Definir';
        versionSO = matchNombre[2] ? matchNombre[2] : 'Sin Definir';
    }

    if (matchFamilia) {
        familiaSO = matchFamilia[1] ? matchFamilia[1] : 'Sin Definir';
    }

    if (/wordpress\/5\.2\.3/i.test(os_navegador)) {
        nombreSO = 'WordPress';
        versionSO = '5.2.3';
    }
}</jsScript_script>
      </jsScript>
    </jsScripts>
    <fields>
      <field>
        <name>nombreSO</name>
        <rename>nombreSO</rename>
        <type>String</type>
        <length>-1</length>
        <precision>-1</precision>
        <replace>N</replace>
      </field>
      <field>
        <name>versionSO</name>
        <rename>versionSO</rename>
        <type>String</type>
        <length>-1</length>
        <precision>-1</precision>
        <replace>N</replace>
      </field>
      <field>
        <name>familiaSO</name>
        <rename>familiaSO</rename>
        <type>String</type>
        <length>-1</length>
        <precision>-1</precision>
        <replace>N</replace>
      </field>
    </fields>
